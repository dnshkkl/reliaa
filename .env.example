# ---------------------------------------------------------------------------
# Reliaa — environment variables
# Copy this file to ".env.local" and fill in the values.
# ---------------------------------------------------------------------------

# Admin login credentials (used to sign in to /admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# Secret used to sign the admin session cookie.
# Generate one with:  openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-string

# ---------------------------------------------------------------------------
# Cloudinary storage (PRODUCTION ONLY)
# Leave this empty for local development — images and data are stored on your
# local disk automatically. In production, paste the "API environment variable"
# from your Cloudinary dashboard (Settings → API Keys). It looks like:
#   cloudinary://<api_key>:<api_secret>@<cloud_name>
# ---------------------------------------------------------------------------
CLOUDINARY_URL=
